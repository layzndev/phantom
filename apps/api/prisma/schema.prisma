generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  admins      Admin[]

  @@map("admin_roles")
}

model Admin {
  id                        String         @id @default(uuid())
  email                     String         @unique
  displayName               String         @map("display_name")
  passwordHash              String         @map("password_hash")
  roleId                    String         @map("role_id")
  role                      AdminRole      @relation(fields: [roleId], references: [id])
  status                    String         @default("active")
  twoFactorEnabled          Boolean        @default(false) @map("two_factor_enabled")
  twoFactorSecretEncrypted  String?        @map("two_factor_secret_encrypted")
  ipAllowlist               Json           @default("[]") @map("ip_allowlist")
  failedLoginAttempts       Int            @default(0) @map("failed_login_attempts")
  lockedUntil               DateTime?      @map("locked_until")
  lastLoginAt               DateTime?      @map("last_login_at")
  createdAt                 DateTime       @default(now()) @map("created_at")
  updatedAt                 DateTime       @updatedAt @map("updated_at")
  sessions                  AdminSession[]
  auditLogs                 AuditLog[]
  notificationsRead         SystemNotification[] @relation("NotificationReadBy")
  notificationsDismissed    SystemNotification[] @relation("NotificationDismissedBy")
  acknowledgedIncidents     Incident[]           @relation("IncidentAcknowledgedBy")
  assignedIncidents         Incident[]           @relation("IncidentAssignedTo")
  incidentEvents            IncidentEvent[]

  @@index([roleId])
  @@index([status])
  @@index([lockedUntil])
  @@map("admins")
}

model AdminSession {
  id        String   @id
  adminId   String?  @map("admin_id")
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  data      Json
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([adminId])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  actorId    String?  @map("actor_id")
  actorEmail String   @map("actor_email")
  actor      Admin?   @relation(fields: [actorId], references: [id], onDelete: SetNull)
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  sessionId  String?  @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Node {
  id              String            @id
  name            String
  provider        String
  region          String
  internalHost    String            @map("internal_host")
  publicHost      String            @map("public_host")
  status          String            @default("offline")
  health          String            @default("unknown")
  runtimeMode     String            @default("remote") @map("runtime_mode")
  totalRamMb      Int?              @map("total_ram_mb")
  usedRamMb       Int               @default(0) @map("used_ram_mb")
  totalCpu        Float?            @map("total_cpu")
  usedCpu         Float             @default(0) @map("used_cpu")
  usedDiskGb      Int               @default(0) @map("used_disk_gb")
  lastHeartbeatAt DateTime?         @map("last_heartbeat_at")
  portRangeStart       Int?         @map("port_range_start")
  portRangeEnd         Int?         @map("port_range_end")
  openPorts            Int[]        @default([]) @map("open_ports")
  openPortDetails      Json?        @map("open_port_details")
  dockerPublishedPorts Json?        @map("docker_published_ports")
  suggestedPortRanges  Json?        @map("suggested_port_ranges")
  agentVersion         String?      @map("agent_version")
  runtimeVersion       String?      @map("runtime_version")
  dockerVersion        String?      @map("docker_version")
  osPlatform           String?      @map("os_platform")
  osRelease            String?      @map("os_release")
  kernelVersion        String?      @map("kernel_version")
  osArch               String?      @map("os_arch")
  hostname             String?
  uptimeSec            Int?         @map("uptime_sec")
  cpuModel             String?      @map("cpu_model")
  cpuCores             Int?         @map("cpu_cores")
  totalDiskGb          Int?         @map("total_disk_gb")
  maintenanceMode      Boolean      @default(false) @map("maintenance_mode")
  pool                 String       @default("free")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  tokens          NodeToken[]
  statusEvents    NodeStatusEvent[]
  notifications   SystemNotification[]
  incidents       Incident[]
  workloads       Workload[]
  connectionEvents ConnectionEvent[]

  @@index([status])
  @@index([health])
  @@index([region])
  @@index([pool])
  @@index([lastHeartbeatAt])
  @@map("nodes")
}

model Incident {
  id               String        @id @default(uuid())
  title            String
  description      String?
  severity         String
  status           String        @default("open")
  scope            String
  sourceType       String?       @map("source_type")
  sourceId         String?       @map("source_id")
  dedupeKey        String        @map("dedupe_key")
  startedAt        DateTime      @default(now()) @map("started_at")
  lastSeenAt       DateTime      @default(now()) @map("last_seen_at")
  resolvedAt       DateTime?     @map("resolved_at")
  acknowledgedAt   DateTime?     @map("acknowledged_at")
  acknowledgedById String?       @map("acknowledged_by_id")
  acknowledgedBy   Admin?        @relation("IncidentAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  assignedToId     String?       @map("assigned_to_id")
  assignedTo       Admin?        @relation("IncidentAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  resolutionType   String?       @map("resolution_type")
  rootCause        String?       @map("root_cause")
  internalNotes    String?       @map("internal_notes")
  metadata         Json?
  nodeId           String?       @map("node_id")
  node             Node?         @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  events           IncidentEvent[]

  @@index([dedupeKey])
  @@index([status])
  @@index([severity])
  @@index([scope])
  @@index([sourceType, sourceId])
  @@index([nodeId])
  @@index([createdAt])
  @@map("incidents")
}

model IncidentEvent {
  id         String   @id @default(uuid())
  incidentId String   @map("incident_id")
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type       String
  message    String
  metadata   Json?
  actorId    String?  @map("actor_id")
  actor      Admin?   @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([incidentId])
  @@index([createdAt])
  @@map("incident_events")
}

model SystemNotification {
  id             String   @id @default(uuid())
  kind           String
  severity       String
  title          String
  body           String
  resourceType   String?  @map("resource_type")
  resourceId     String?  @map("resource_id")
  nodeId         String?  @map("node_id")
  node           Node?    @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  metadata       Json?
  readAt         DateTime? @map("read_at")
  readByAdminId  String?   @map("read_by_admin_id")
  readByAdmin    Admin?    @relation("NotificationReadBy", fields: [readByAdminId], references: [id], onDelete: SetNull)
  dismissedAt    DateTime? @map("dismissed_at")
  dismissedByAdminId String? @map("dismissed_by_admin_id")
  dismissedByAdmin   Admin?  @relation("NotificationDismissedBy", fields: [dismissedByAdminId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([severity])
  @@index([kind])
  @@index([readAt])
  @@index([dismissedAt])
  @@index([nodeId])
  @@map("system_notifications")
}

model NodeToken {
  id        String    @id @default(uuid())
  nodeId    String    @map("node_id")
  node      Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  tokenHash String    @map("token_hash")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@index([nodeId])
  @@index([revokedAt])
  @@map("node_tokens")
}

model NodeStatusEvent {
  id             String   @id @default(uuid())
  nodeId         String   @map("node_id")
  node           Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  previousStatus String?  @map("previous_status")
  newStatus      String   @map("new_status")
  reason         String?
  acknowledgedAt DateTime? @map("acknowledged_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([nodeId])
  @@index([createdAt])
  @@index([acknowledgedAt])
  @@map("node_status_events")
}

model Workload {
  id              String   @id @default(uuid())
  name            String
  type            String
  image           String
  nodeId          String?  @map("node_id")
  node            Node?    @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  status          String   @default("pending")
  desiredStatus   String   @default("running") @map("desired_status")

  requestedCpu    Float    @map("requested_cpu")
  requestedRamMb  Int      @map("requested_ram_mb")
  requestedDiskGb Int      @map("requested_disk_gb")

  config          Json     @default("{}")
  containerId     String?  @map("container_id")
  lastHeartbeatAt DateTime? @map("last_heartbeat_at")
  runtimeStartedAt DateTime? @map("runtime_started_at")
  runtimeFinishedAt DateTime? @map("runtime_finished_at")
  runtimeCpuPercent Float?  @map("runtime_cpu_percent")
  runtimeMemoryMb  Int?     @map("runtime_memory_mb")
  runtimeDiskGb    Float?   @map("runtime_disk_gb")
  lastExitCode    Int?     @map("last_exit_code")
  restartCount    Int      @default(0) @map("restart_count")
  deleteRequestedAt DateTime? @map("delete_requested_at")
  deleteRuntimeAckAt DateTime? @map("delete_runtime_ack_at")
  deleteHardData  Boolean  @default(false) @map("delete_hard_data")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt       @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  ports               WorkloadPort[]
  statusEvents        WorkloadStatusEvent[]
  minecraftServer     MinecraftServer?
  minecraftOperations MinecraftOperation[]

  @@index([nodeId])
  @@index([status])
  @@index([type])
  @@index([deletedAt])
  @@index([deleteRequestedAt])
  @@map("workloads")
}

model WorkloadPort {
  id           String   @id @default(uuid())
  workloadId   String   @map("workload_id")
  workload     Workload @relation(fields: [workloadId], references: [id], onDelete: Cascade)
  nodeId       String   @map("node_id")
  internalPort Int      @map("internal_port")
  externalPort Int      @map("external_port")
  protocol     String   @default("tcp")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([nodeId, externalPort, protocol])
  @@index([workloadId])
  @@map("workload_ports")
}

model WorkloadStatusEvent {
  id             String   @id @default(uuid())
  workloadId     String   @map("workload_id")
  workload       Workload @relation(fields: [workloadId], references: [id], onDelete: Cascade)
  previousStatus String?  @map("previous_status")
  newStatus      String   @map("new_status")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([workloadId])
  @@index([createdAt])
  @@map("workload_status_events")
}

model MinecraftServer {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  hostname         String?   @unique
  hostnameSlug     String?   @unique @map("hostname_slug")
  hostnameUpdatedAt DateTime? @map("hostname_updated_at")
  dnsStatus        String    @default("wildcard") @map("dns_status")
  dnsLastError     String?   @map("dns_last_error")
  dnsSyncedAt      DateTime? @map("dns_synced_at")
  workloadId       String    @unique @map("workload_id")
  workload         Workload  @relation(fields: [workloadId], references: [id], onDelete: Cascade)
  templateId       String    @map("template_id")
  minecraftVersion String    @map("minecraft_version")
  motd             String?
  difficulty       String    @default("normal")
  gameMode         String    @default("survival") @map("game_mode")
  maxPlayers       Int       @default(20) @map("max_players")
  eula             Boolean   @default(false)
  planTier         String    @default("free") @map("plan_tier")
  autoSleepUseGlobalDefaults Boolean @default(true) @map("auto_sleep_use_global_defaults")
  autoSleepEnabled Boolean   @default(true) @map("auto_sleep_enabled")
  autoSleepIdleMinutes Int   @default(10) @map("auto_sleep_idle_minutes")
  autoSleepAction String     @default("sleep") @map("auto_sleep_action")
  onlineMode      Boolean    @default(true) @map("online_mode")
  whitelistEnabled Boolean   @default(false) @map("whitelist_enabled")
  currentPlayerCount Int     @default(0) @map("current_player_count")
  lastPlayerSampleAt DateTime? @map("last_player_sample_at")
  lastPlayerCheckFailedAt DateTime? @map("last_player_check_failed_at")
  lastPlayerCheckError String? @map("last_player_check_error")
  lastPlayerSeenAt  DateTime? @map("last_player_seen_at")
  lastConsoleCommandAt DateTime? @map("last_console_command_at")
  lastActivityAt    DateTime? @map("last_activity_at")
  idleSince         DateTime? @map("idle_since")
  sleepRequestedAt  DateTime? @map("sleep_requested_at")
  sleepingAt        DateTime? @map("sleeping_at")
  wakeRequestedAt   DateTime? @map("wake_requested_at")
  readyAt           DateTime? @map("ready_at")
  serverProperties Json      @default("{}") @map("server_properties")
  rconPassword     String?   @map("rcon_password")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  connectionEvents ConnectionEvent[]
  playerRelations PlayerServerRelation[]

  @@index([templateId])
  @@index([deletedAt])
  @@index([planTier])
  @@index([hostnameSlug])
  @@index([dnsStatus])
  @@map("minecraft_servers")
}

model MinecraftGlobalSettings {
  id                     String   @id
  freeAutoSleepEnabled   Boolean  @default(true) @map("free_auto_sleep_enabled")
  freeAutoSleepIdleMinutes Int    @default(10) @map("free_auto_sleep_idle_minutes")
  freeAutoSleepAction    String   @default("sleep") @map("free_auto_sleep_action")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("minecraft_global_settings")
}

model MinecraftOperation {
  id          String    @id @default(uuid())
  workloadId  String    @map("workload_id")
  workload    Workload  @relation(fields: [workloadId], references: [id], onDelete: Cascade)
  kind        String
  payload     Json      @default("{}")
  status      String    @default("pending")
  result      Json?
  error       String?
  actorId     String?   @map("actor_id")
  actorEmail  String?   @map("actor_email")
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([workloadId])
  @@index([status])
  @@index([createdAt])
  @@map("minecraft_operations")
}

model ConnectionEvent {
  id                 String          @id @default(uuid())
  createdAt          DateTime        @default(now()) @map("created_at")
  serverId           String?         @map("server_id")
  server             MinecraftServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  nodeId             String?         @map("node_id")
  node               Node?           @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  hostname           String?
  sourceIp           String?         @map("source_ip")
  sourceIpHash       String          @map("source_ip_hash")
  countryCode        String?         @map("country_code")
  region             String?
  city               String?
  asn                String?
  isp                String?
  usernameAttempted  String?         @map("username_attempted")
  normalizedUsername String?         @map("normalized_username")
  onlineMode         Boolean?        @map("online_mode")
  protocolVersion    Int?            @map("protocol_version")
  clientBrand        String?         @map("client_brand")
  action             String
  disconnectReason   String?         @map("disconnect_reason")
  latencyMs          Int?            @map("latency_ms")
  sessionId          String?         @map("session_id")
  metadata           Json            @default("{}")

  @@index([createdAt])
  @@index([serverId, createdAt])
  @@index([nodeId, createdAt])
  @@index([sourceIpHash, createdAt])
  @@index([countryCode, createdAt])
  @@index([normalizedUsername, createdAt])
  @@index([action, createdAt])
  @@index([sessionId])
  @@map("connection_events")
}

model PlayerProfile {
  normalizedUsername String   @id @map("normalized_username")
  displayUsername    String?  @map("display_username")
  firstSeenAt        DateTime @default(now()) @map("first_seen_at")
  lastSeenAt         DateTime @default(now()) @map("last_seen_at")
  totalConnections   Int      @default(0) @map("total_connections")
  totalServersVisited Int     @default(0) @map("total_servers_visited")
  totalPlaySessions  Int      @default(0) @map("total_play_sessions")
  riskScore          Int      @default(0) @map("risk_score")
  trusted            Boolean  @default(false)
  notes              String?
  serverRelations    PlayerServerRelation[]

  @@index([lastSeenAt])
  @@index([riskScore])
  @@map("player_profiles")
}

model PlayerServerRelation {
  id                 String          @id @default(uuid())
  username           String          @map("normalized_username")
  player             PlayerProfile   @relation(fields: [username], references: [normalizedUsername], onDelete: Cascade)
  serverId           String          @map("server_id")
  server             MinecraftServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  joins              Int             @default(0)
  lastSeenAt         DateTime        @default(now()) @map("last_seen_at")
  totalPlayMinutes   Int             @default(0) @map("total_play_minutes")

  @@unique([username, serverId])
  @@index([serverId])
  @@index([lastSeenAt])
  @@map("player_server_relations")
}

model GuardIpProfile {
  sourceIpHash       String   @id @map("source_ip_hash")
  sourceIp           String?  @map("source_ip")
  firstSeenAt        DateTime @default(now()) @map("first_seen_at")
  lastSeenAt         DateTime @default(now()) @map("last_seen_at")
  totalConnections   Int      @default(0) @map("total_connections")
  totalServersTargeted Int    @default(0) @map("total_servers_targeted")
  totalUsernames     Int      @default(0) @map("total_usernames")
  riskScore          Int      @default(0) @map("risk_score")
  trusted            Boolean  @default(false)
  notes              String?

  @@index([lastSeenAt])
  @@index([riskScore])
  @@map("guard_ip_profiles")
}

model GuardRule {
  id                 String    @id @default(uuid())
  targetScope        String    @map("target_scope")
  targetValue        String?   @map("target_value")
  targetHash         String?   @map("target_hash")
  action             String
  reason             String?
  note               String?
  rateLimitPerMinute Int?      @map("rate_limit_per_minute")
  delayMs            Int?      @map("delay_ms")
  expiresAt          DateTime? @map("expires_at")
  createdByAdminId   String?   @map("created_by_admin_id")
  createdByEmail     String?   @map("created_by_email")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([targetScope, targetValue])
  @@index([targetScope, targetHash])
  @@index([action])
  @@index([expiresAt])
  @@map("guard_rules")
}

model GuardSettings {
  id                      String   @id
  rawIpRetentionDays      Int      @default(30) @map("raw_ip_retention_days")
  aggregateRetentionDays  Int      @default(365) @map("aggregate_retention_days")
  hashIpsAfterRetention   Boolean  @default(true) @map("hash_ips_after_retention")
  privacyMode             Boolean  @default(false) @map("privacy_mode")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("guard_settings")
}
